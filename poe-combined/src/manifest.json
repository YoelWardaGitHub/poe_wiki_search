{
  "manifest_version": 3,
  "name": "PoE Quick Search (Wiki + DB)",
  "version": "1.0.0",
  "description": "Type 'poe' to search the Path of Exile Wiki, or 'poe db ...' to search poedb.tw.",
  "omnibox": {
    "keyword": "poe"
  },
  "background": {
    "service_worker": "background.js",
    "scripts": ["background.js"]
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "poe-quick-search@yoelwarda",
      "strict_min_version": "140.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    },
    "gecko_android": {
      "strict_min_version": "142.0"
    }
  },
  "icons": {
    "16": "icon-16.png",
    "48": "icon-48.png",
    "128": "icon.png"
  }
}
